# EdgeTier v0.1.2 real-node validation secrets/local settings.
# This file is ignored by git via `.env.*`. Do not commit real values.

# Cloudflare private test endpoint. Example shape: edge.example.com
EDGETIER_EDGE_DOMAIN=

# Room name used by the validation matrix. Do not put network_secret here.
EDGETIER_ROOM=home-mesh

# Derived WSS peer URI. Fill after EDGETIER_EDGE_DOMAIN is known.
EDGETIER_WSS_URI=wss://<edge-domain>/ws?room=home-mesh

# Optional metadata for the sanitized validation report.
EASYTIER_VERSION=
NODE_A_PLATFORM=
NODE_B_PLATFORM=

# Optional local notes. Do not include network_secret, private IPs, private hostnames, or unredacted logs.
VALIDATION_NOTES=
